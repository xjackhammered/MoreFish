                if devConInfo:
                    response = {
                        'success': 'True',
                        'status code': status.HTTP_200_OK,
                        'message': 'Device is ON'
                    }
                    return Response(response)
                else:
                    pass

                url = "http://dma.com.bd:8888/send/sms"
                message = {'number': phone_number, 'message': 'ON'}
                r = requests.post(url, message)
                print(r)
                time.sleep(10)
                response = {
                        'success': 'True',
                        'status code': status.HTTP_200_OK,
