                        'success': 'True',
                        'status code': status.HTTP_200_OK,
                        'message': 'Device is OFF'
                    }
                    return Response(response)
                else:
                    response = {
                        'success': 'True',
                        'status code': status.HTTP_200_OK,
                        'message': 'Internet Problem'
                    }
                    return Response(response)
        else:
            response = {
                'success': 'True',
                'status code': status.HTTP_200_OK,
                'message': 'Device Not Found'
            }
            return Response(response)
